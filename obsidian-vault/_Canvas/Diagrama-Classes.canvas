		{"id":"machine-reading-class","type":"text","text":"📊 MACHINE_READING\n\nAttributes:\n- id (PK)\n- machine_id (FK)\n- sensor_key\n- value (decimal)\n- unit\n- read_at (timestamp)\n\nExamples:\n- temperature (°C)\n- vibration (mm/s)\n- rpm (RPM)","x":-380,"y":-420,"width":260,"height":420,"color":"#3498db"},
		{"id":"user-class","type":"text","text":"👤 USER\n\nAttributes:\n- id (PK)\n- name\n- email\n- password\n\nMethods:\n- hasRole()\n- hasPermissionTo()\n- can()\n\nRelations:\n- serviceOrders()\n- roles() N-N","x":-935,"y":539,"width":220,"height":461,"color":"#3498db"},
