		{"id":"enum-status","type":"text","text":"⚙️ Status\n(Enum)\n\n- operational\n- maintenance\n- critical\n- offline","x":0,"y":390,"width":130,"height":120,"color":"#95a5a6"},
		{"id":"machine-class","type":"text","text":"🏢 MACHINE\n\nAttributes:\n- id (PK)\n- serial_number ★\n- name, model\n- location, status\n- installed_at\n- last_reading_at\n\nScopes:\n- operational()\n- critical()\n\nBoot Hook:\n- Cria StatusAlert\n- Notifica","x":-40,"y":-170,"width":210,"height":490,"color":"#f39c12"},
