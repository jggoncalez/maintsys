{
	"nodes":[
		{"id":"service-order-class","type":"text","text":"📋 SERVICE_ORDER\n\nAttributes:\n- id (PK)\n- machine_id (FK)\n- technician_id (FK)\n- type (preventive/corrective)\n- priority (enum)\n- status (enum)\n- started_at, completed_at\n\nMethods:\n- isOpen()\n- start()\n- complete(notes)","x":300,"y":0,"width":180,"height":220,"color":"#27ae60"},
		{"id":"maintenance-log-class","type":"text","text":"📝 MAINTENANCE_LOG\n\nAttributes:\n- id (PK)\n- machine_id (FK)\n- service_order_id (FK)\n- user_id (FK)\n- action (string)\n- defect_type\n- logged_at\n\nRelations:\n- machine()\n- serviceOrder()\n- user()","x":300,"y":250,"width":180,"height":200,"color":"#16a085"},
		{"id":"status-alert-class","type":"text","text":"🚨 STATUS_ALERT\n\nAttributes:\n- id (PK)\n- machine_id (FK)\n- triggered_by (FK)\n- previous_status\n- new_status\n- message\n- is_read\n- triggered_at\n\nTrigger: Boot Hook","x":600,"y":250,"width":180,"height":200,"color":"#e74c3c"},
		{"id":"filament-resource","type":"text","text":"🎨 FILAMENT RESOURCES\n\n- MachineResource\n- ServiceOrderResource\n- MaintenanceLogResource\n- StatusAlertResource\n- UserResource","x":-900,"y":0,"width":150,"height":140,"color":"#1abc9c"},
